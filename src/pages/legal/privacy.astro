---
import Layout from '../../layouts/Layout.astro';
import { getPageBySlug } from '../../lib/microcms';
import { localized } from '../../types/microcms';

const lang = 'ja' as const;
const page = await getPageBySlug('privacy');

const title = page ? localized(page, 'title', lang) : 'プライバシーポリシー';
const subtitle = page?.title_en ?? 'Privacy Policy';
const body = page ? localized(page, 'body', lang) : '';
const description = page ? localized(page, 'meta_description', lang) : undefined;
---

<Layout title={title} description={description} lang={lang}>
  <section class="py-20 max-w-3xl mx-auto px-4">
    <h1 class="text-2xl md:text-3xl font-bold border-l-4 border-accent-400 pl-3 mb-2 text-brand-900">
      {title}
    </h1>
    <p class="text-sm text-slate-500 mb-10 ml-1">{subtitle}</p>
    <div class="prose-jp" set:html={body}></div>
  </section>
</Layout>
