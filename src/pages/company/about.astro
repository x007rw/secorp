---
import Layout from '../../layouts/Layout.astro';

const lang = 'ja' as const;

const profile = [
  { label: '会社名', value: '株式会社 鈴木エンタープライズ' },
  { label: '英文社名', value: 'SUZUKI ENTERPRISE CO., LTD.' },
  { label: '本社所在地', value: '〒211-0025 神奈川県川崎市中原区木月2-2-34 鈴木ビル3F' },
  { label: '電話・FAX', value: 'TEL: 044-433-6399 / FAX: 044-434-8488' },
  { label: '設立', value: '1967年7月' },
  { label: '資本金', value: '8,000万円' },
  { label: '法人番号', value: '3020001076051' },
  { label: '事業内容', value: '土木・建設・プラント分野向け鉄鋼・非鉄金属原材料および加工品の輸入・卸売' },
  { label: '主要取扱品', value: 'シールドセグメント（鋼製・RC）、コンクリート補強材、防音・保温材、プラント設備資材、IoTセンサー' },
  { label: '主要取引先', value: '国土交通省関連の公共事業、鉄道・電力・通信インフラ、ゼネコン各社、エンジニアリング会社' },
];
---

<Layout
  title="会社概要"
  description="株式会社鈴木エンタープライズの会社概要。1967年創業、川崎市中原区を拠点とする土木・建設資材の専門商社。シールドセグメント、コンクリート補強材を主力に取り扱います。"
  lang={lang}
>
  <div class="bg-gradient-to-br from-brand to-brand-light text-white py-16">
    <div class="max-w-6xl mx-auto px-4">
      <p class="text-accent text-sm font-semibold tracking-wider mb-2">COMPANY PROFILE</p>
      <h1 class="text-3xl md:text-5xl font-bold">会社概要</h1>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 py-16">
    <div class="prose-jp">
      <h2>基本情報</h2>
      <table>
        <tbody>
          {profile.map((row) => (
            <tr>
              <th class="w-1/3 align-top">{row.label}</th>
              <td>{row.value}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <h2>事業概要</h2>
      <p>
        株式会社鈴木エンタープライズは、土木・建設・プラント分野向けに、世界各国から高品質・低コストの資材を調達し、日本の発展に貢献する商社です。
      </p>
      <p>
        半世紀以上にわたり東アジアを中心に鉄鋼・土木建築資材の品質向上とコスト削減に取り組んでまいりました。シールド工法用セグメントでは、首都高速道路公団・NEXCO東日本・横浜市営地下鉄・シンガポールMRT等への納入実績があり、コンクリート補強材分野では自社ブランド「バンドレックス®」「POWER MESH」を中心に建設・補修現場で広く採用されています。
      </p>

      <h2>主要納入実績（抜粋）</h2>
      <ul>
        <li>首都高速道路公団 各種補強工事</li>
        <li>NEXCO東日本 みちのく橋増強工事</li>
        <li>横浜市営地下鉄 4号線 各工区</li>
        <li>シンガポール地下鉄 C-823 工区（RCセグメント）</li>
        <li>レインボーブリッジ他 増強工事</li>
        <li>中部電力向け 連系管路新設工事 ほか多数</li>
      </ul>

      <h2>関連リソース</h2>
      <ul>
        <li><a href="/downloads/track-record-domestic.pdf">主要取扱品目 国内実績表（PDF）</a></li>
        <li><a href="/downloads/rc-segment-results.pdf">RCセグメント実績表（PDF）</a></li>
      </ul>
    </div>
  </div>
</Layout>
