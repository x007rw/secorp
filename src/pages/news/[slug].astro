---
import Layout from '../../layouts/Layout.astro';
import { getLocalizedPath } from '../../i18n/ui';
import { getNews } from '../../lib/microcms';
import { localized } from '../../types/microcms';

export async function getStaticPaths() {
  const newsList = await getNews(100);
  return newsList.map((n) => ({
    params: { slug: n.slug },
    props: { news: n },
  }));
}

const { news } = Astro.props;
const lang = 'ja' as const;
const p = (path: string) => getLocalizedPath(path, lang);

const title = localized(news, 'title', lang);
const body = localized(news, 'body', lang);
---

<Layout title={title} lang={lang}>
  <section class="py-20 max-w-3xl mx-auto px-4">
    <nav class="text-sm text-slate-500 mb-4">
      <a href={p('/news/')} class="hover:text-brand-600">お知らせ</a>
      <span class="mx-2">/</span>
      <span class="truncate">{title}</span>
    </nav>

    <time class="block text-xs text-slate-500 font-mono mb-2">
      {new Date(news.published_at).toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
    </time>

    <h1 class="text-2xl md:text-3xl font-bold border-l-4 border-accent-400 pl-3 mb-8 text-brand-900">
      {title}
    </h1>

    {news.thumbnail && (
      <img src={news.thumbnail.url} alt={title} class="w-full rounded shadow-sm border border-slate-200 mb-8" />
    )}

    <div class="prose-jp text-slate-700 leading-relaxed" set:html={body} />

    <div class="mt-12 pt-8 border-t border-slate-200">
      <a href={p('/news/')} class="text-brand-600 font-semibold hover:text-accent-600">
        ← お知らせ一覧に戻る
      </a>
    </div>
  </section>
</Layout>
