---
import Layout from '../../../layouts/Layout.astro';
const lang = 'en' as const;
---

<Layout
  title="Contact Us"
  description="Contact SUZUKI ENTERPRISE CO., LTD. for inquiries about shield segments, concrete reinforcement materials, and plant equipment."
  lang={lang}
>
  <div class="bg-gradient-to-br from-brand to-brand-light text-white py-16">
    <div class="max-w-6xl mx-auto px-4">
      <p class="text-accent text-sm font-semibold tracking-wider mb-2">CONTACT</p>
      <h1 class="text-3xl md:text-5xl font-bold">Contact Us</h1>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-4 py-16">
    <div class="prose-jp mb-10">
      <p>For inquiries about products, quotations, or business partnership, please feel free to contact us.</p>

      <h2>By Phone</h2>
      <div class="bg-gray-50 p-6 rounded-lg my-4 not-prose">
        <p class="text-2xl font-bold text-brand">
          <a href="tel:+81444336399">+81-44-433-6399</a>
        </p>
        <p class="text-sm text-gray-600 mt-1">Mon-Fri 9:00–17:30 JST</p>
        <p class="text-sm text-gray-600">FAX: +81-44-434-8488</p>
      </div>
    </div>

    <form class="bg-white border border-gray-200 rounded-lg p-6 md:p-8 space-y-5" action="https://formspree.io/f/REPLACE_ME" method="POST">
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">Inquiry Type *</label>
        <select name="inquiry_type" required class="w-full border border-gray-300 rounded-md px-3 py-2">
          <option value="">Please select</option>
          <option value="product">Product inquiry</option>
          <option value="quote">Quote request</option>
          <option value="partnership">Business partnership</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div class="grid md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Company *</label>
          <input type="text" name="company" required class="w-full border border-gray-300 rounded-md px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Title</label>
          <input type="text" name="department" class="w-full border border-gray-300 rounded-md px-3 py-2" />
        </div>
      </div>

      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">Name *</label>
        <input type="text" name="name" required class="w-full border border-gray-300 rounded-md px-3 py-2" />
      </div>

      <div class="grid md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Email *</label>
          <input type="email" name="email" required class="w-full border border-gray-300 rounded-md px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1">Phone</label>
          <input type="tel" name="tel" class="w-full border border-gray-300 rounded-md px-3 py-2" />
        </div>
      </div>

      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">Message *</label>
        <textarea name="message" required rows="6" class="w-full border border-gray-300 rounded-md px-3 py-2"></textarea>
      </div>

      <div>
        <label class="flex items-start gap-2 text-sm">
          <input type="checkbox" required class="mt-1" />
          <span>I agree to the <a href="/en/legal/privacy/" class="text-accent underline">Privacy Policy</a>. *</span>
        </label>
      </div>

      <button type="submit" class="w-full md:w-auto px-8 py-3 bg-brand text-white font-semibold rounded-md hover:bg-accent transition-colors">
        Submit →
      </button>
    </form>
  </div>
</Layout>
