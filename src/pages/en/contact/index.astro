---
import Layout from '../../../layouts/Layout.astro';
const lang = 'en' as const;
---

<Layout
  title="Contact"
  description="Contact SUZUKI ENTERPRISE CO., LTD. for inquiries about shield segments, concrete reinforcement materials, and moulds."
  lang={lang}
>
  <section class="py-20 max-w-4xl mx-auto px-4">
    <h1 class="text-2xl md:text-3xl font-bold border-l-4 border-accent-400 pl-3 mb-2 text-brand-900">
      Contact
    </h1>
    <p class="text-sm text-slate-500 mb-10 ml-1">お問い合わせ</p>

    <div class="bg-white border border-slate-200 rounded p-6 md:p-8 shadow-sm">
      <p class="mb-6 text-slate-600 text-sm">Reach us by phone, fax, or the form below.</p>

      <div class="grid sm:grid-cols-2 gap-4 text-sm mb-8">
        <div class="bg-slate-50 rounded p-4">
          <p class="text-xs text-slate-500">TEL</p>
          <a href="tel:+81444336399" class="text-lg font-semibold text-brand-600">+81-44-433-6399</a>
          <p class="text-xs text-slate-500 mt-1">Mon-Fri 9:00–17:30 JST</p>
        </div>
        <div class="bg-slate-50 rounded p-4">
          <p class="text-xs text-slate-500">FAX</p>
          <p class="text-lg font-semibold text-slate-800">+81-44-434-8488</p>
        </div>
      </div>

      <form action="https://formspree.io/f/your-id-here" method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-semibold mb-1 text-slate-700">Name<span class="text-red-500">*</span></label>
          <input required name="name" type="text" class="w-full border border-slate-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-accent-400 focus:border-transparent" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-1 text-slate-700">Company</label>
          <input name="company" type="text" class="w-full border border-slate-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-accent-400 focus:border-transparent" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-1 text-slate-700">Email<span class="text-red-500">*</span></label>
          <input required name="email" type="email" class="w-full border border-slate-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-accent-400 focus:border-transparent" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-1 text-slate-700">Message<span class="text-red-500">*</span></label>
          <textarea required name="message" rows="6" class="w-full border border-slate-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-accent-400 focus:border-transparent"></textarea>
        </div>
        <div>
          <label class="flex items-start gap-2 text-sm text-slate-600">
            <input type="checkbox" required class="mt-1" />
            <span>I agree to the <a href="/en/legal/privacy/" class="text-brand-600 underline">Privacy Policy</a>.<span class="text-red-500">*</span></span>
          </label>
        </div>
        <button type="submit" class="bg-brand-900 text-white font-semibold px-6 py-3 rounded hover:bg-brand-700 transition-colors">Send</button>
      </form>
    </div>
  </section>
</Layout>
