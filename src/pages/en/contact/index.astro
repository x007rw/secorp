---
import Layout from '../../../layouts/Layout.astro';
import ContactCards from '../../../components/ContactCards.astro';
const lang = 'en' as const;
---

<Layout
  title="Contact"
  description="Contact SUZUKI ENTERPRISE CO., LTD. for inquiries about shield segments, concrete reinforcement materials, and moulds. Reach us by email, phone, or fax."
  lang={lang}
>
  <section class="py-20 max-w-4xl mx-auto px-4">
    <h1 class="text-2xl md:text-3xl font-bold border-l-4 border-accent-400 pl-3 mb-2 text-brand-900">
      Contact
    </h1>
    <p class="text-sm text-slate-500 mb-10 ml-1">お問い合わせ</p>

    <p class="mb-8 text-slate-700 leading-relaxed">
      For inquiries about product specifications, quotations, or business partnership, please contact us via the channels below. We will reply within two business days.
    </p>

    <ContactCards lang="en" />

    <!-- Inquiry guide -->
    <div class="mt-12 bg-slate-50 border-l-4 border-accent-400 p-6 rounded-r">
      <h2 class="text-base font-bold text-brand-900 mb-3">Information helpful to include</h2>
      <ul class="text-sm text-slate-700 space-y-1.5 list-disc pl-5">
        <li>Your name, company, and department</li>
        <li>Project name (if disclosable)</li>
        <li>Target product (Shield Segment, Concrete Reinforcement, etc.)</li>
        <li>Required quantity and delivery schedule</li>
        <li>Specifications, standards, and drawings (if any)</li>
      </ul>
      <p class="text-xs text-slate-500 mt-4">
        * Not all fields are required. Please share what is available.
      </p>
    </div>
  </section>
</Layout>
