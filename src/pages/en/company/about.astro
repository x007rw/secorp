---
import Layout from '../../../layouts/Layout.astro';
const lang = 'en' as const;

const profile = [
  { label: 'Company Name', value: 'SUZUKI ENTERPRISE CO., LTD.' },
  { label: 'Headquarters', value: 'SUZUKI BLDG. 3F, 2-2-34 Kizuki, Nakahara-ku, Kawasaki, Kanagawa 211-0025, JAPAN' },
  { label: 'Phone / Fax', value: 'TEL: +81-44-433-6399 / FAX: +81-44-434-8488' },
  { label: 'Founded', value: 'July 1967' },
  { label: 'Capital', value: '80,000,000 JPY' },
  { label: 'Corporate Number', value: '3020001076051' },
  { label: 'Business', value: 'Import and wholesale of steel/non-ferrous raw materials and processed products for civil engineering, construction, and plant industries' },
  { label: 'Main Products', value: 'Shield segments (Steel/RC), concrete reinforcement materials, insulation, plant equipment, IoT sensors' },
];
---

<Layout
  title="Company Profile"
  description="Profile of SUZUKI ENTERPRISE CO., LTD. Founded in 1967 in Kawasaki, Japan. Trading specialist of shield segments and concrete reinforcement materials."
  lang={lang}
>
  <div class="bg-gradient-to-br from-brand to-brand-light text-white py-16">
    <div class="max-w-6xl mx-auto px-4">
      <p class="text-accent text-sm font-semibold tracking-wider mb-2">COMPANY PROFILE</p>
      <h1 class="text-3xl md:text-5xl font-bold">Company Profile</h1>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 py-16">
    <div class="prose-jp">
      <h2>Basic Information</h2>
      <table>
        <tbody>
          {profile.map((row) => (
            <tr>
              <th class="w-1/3 align-top">{row.label}</th>
              <td>{row.value}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <h2>Business Overview</h2>
      <p>
        SUZUKI ENTERPRISE CO., LTD. procures high-quality, cost-effective civil
        engineering and construction materials from around the world to support
        Japan's infrastructure development.
      </p>
      <p>
        For over half a century, we have worked primarily across East Asia on
        improving the quality and reducing the cost of steel and construction
        materials. Our shield-segment business has supplied projects including
        Tokyo Metropolitan Expressway, NEXCO East Japan, Yokohama Municipal
        Subway, and Singapore MRT.
      </p>
    </div>
  </div>
</Layout>
