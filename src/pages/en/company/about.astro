---
import Layout from '../../../layouts/Layout.astro';
const lang = 'en' as const;

const profile = [
  { label: 'Company', value: 'SUZUKI ENTERPRISE CO., LTD. (株式会社鈴木エンタープライズ)' },
  { label: 'Address', value: 'Suzuki Bldg. 3F, 2-2-34 Kizuki, Nakahara-ku, Kawasaki, Kanagawa 211-0025, JAPAN' },
  { label: 'TEL / FAX', value: 'TEL: +81-44-433-6399 / FAX: +81-44-434-8488' },
  { label: 'Founded', value: 'July 1967' },
  { label: 'Capital', value: '80,000,000 JPY' },
  { label: 'Corporate Number', value: '3020001076051' },
  { label: 'Representative', value: 'Hiroya Suzuki, President' },
  { label: 'Business', value: 'Import and wholesale of steel and non-ferrous raw materials and processed products for civil engineering, construction, and plant industries' },
  { label: 'Banks', value: 'SMBC, Bank of Yokohama, Johnan Shinkin Bank' },
];
---

<Layout
  title="Company Overview"
  description="SUZUKI ENTERPRISE CO., LTD. company profile. Founded in 1967 in Kawasaki, Japan. Trading specialist of shield segments and concrete reinforcement materials."
  lang={lang}
>
  <section class="py-20 max-w-6xl mx-auto px-4">
    <h1 class="text-2xl md:text-3xl font-bold border-l-4 border-accent-400 pl-3 mb-2 text-brand-900">
      Company Overview
    </h1>
    <p class="text-sm text-slate-500 mb-10 ml-1">会社概要</p>

    <div class="grid md:grid-cols-2 gap-10">
      <dl class="divide-y divide-slate-200 text-sm">
        {profile.map((row) => (
          <div class="grid grid-cols-3 gap-3 py-3.5">
            <dt class="font-semibold text-slate-600 col-span-1">{row.label}</dt>
            <dd class="col-span-2 text-slate-800">{row.value}</dd>
          </div>
        ))}
      </dl>

      <div>
        <iframe
          class="w-full h-72 rounded shadow-sm border border-slate-200"
          src="https://maps.google.co.jp/maps?q=Japan,kanagawa,kawasaki,nakaharaku,kizuki%202-2-34&z=15&output=embed"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Map"
        ></iframe>
        <p class="mt-3 text-xs text-slate-500">
          1 min walk from Motosumiyoshi Stn. (Tokyu Toyoko / Meguro Line)<br />
          15 min walk from Musashi-Kosugi Stn. (JR / Tokyu)
        </p>
      </div>
    </div>
  </section>
</Layout>
