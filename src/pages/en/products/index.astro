---
import Layout from '../../../layouts/Layout.astro';
import { getLocalizedPath } from '../../../i18n/ui';
import { getProducts } from '../../../lib/microcms';
import { localized } from '../../../types/microcms';

const lang = 'en' as const;
const p = (path: string) => getLocalizedPath(path, lang);

const products = await getProducts();
---

<Layout
  title="Products"
  description="Our product lineup: RC and steel shield-tunnel segments, civil/architectural moulds, steel fiber (KOSTEEL BUNDREX®), and polypropylene fiber."
  lang={lang}
>
  <section class="py-20 max-w-6xl mx-auto px-4">
    <h1 class="text-2xl md:text-3xl font-bold border-l-4 border-accent-400 pl-3 mb-2 text-brand-900">
      Products
    </h1>
    <p class="text-sm text-slate-500 mb-10 ml-1">Civil Engineering &amp; Construction Materials</p>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {products.map((product) => (
        <a
          href={p(`/products/${product.slug}/`)}
          class="group bg-white border border-slate-200 rounded overflow-hidden shadow-sm hover:shadow-md hover:border-accent-400 transition-all"
        >
          <div class="aspect-video overflow-hidden bg-slate-100">
            <img
              src={product.image.url}
              alt={localized(product, 'title', lang)}
              width="800"
              height="450"
              loading="lazy"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="p-5">
            <h3 class="font-bold mb-2 text-brand-900 group-hover:text-brand-600 transition-colors">
              {localized(product, 'title', lang)}
            </h3>
            <p class="text-sm text-slate-600 leading-relaxed">{localized(product, 'excerpt', lang)}</p>
            <span class="inline-block mt-3 text-xs font-semibold text-accent-600">Learn more →</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
