---
import Layout from '../../../layouts/Layout.astro';
import { getLocalizedPath } from '../../../i18n/ui';
const lang = 'en' as const;
const p = (path: string) => getLocalizedPath(path, lang);

const products = [
  { title: 'RC Segment', desc: 'Reinforced-concrete shield-tunnel lining segments, manufactured at overseas partner plants under Japanese-grade quality control.', href: '/products/shield-segment/rc/', img: '/images/products/rc-segment.webp' },
  { title: 'Steel Segment', desc: 'Steel lining segments for gas, subway, and road tunnels — produced to ±1 mm dimensional tolerance.', href: '/products/shield-segment/steel/', img: '/images/products/steel-segment.webp' },
  { title: 'Moulds (Formwork)', desc: 'High-precision formwork including RC-segment moulds (±0.5 mm), and PC slab moulds for highway repair.', href: '/products/mold/', img: '/images/products/mould.webp' },
  { title: 'Steel Fiber (BUNDREX®)', desc: 'Structural reinforcement fiber for RC. Sole Japanese distributor of KOSTEEL BUNDREX® (Korea).', href: '/products/concrete-reinforcement/bundrex/', img: '/images/products/steel-fiber.webp' },
  { title: 'Polypropylene Fiber', desc: 'Non-structural PP fiber preventing cracking and spalling. Supplied to leading Japanese general contractors.', href: '/products/concrete-reinforcement/pp-fiber/', img: '/images/products/pp-fiber.webp' },
];
---

<Layout
  title="Products"
  description="Product lineup of SUZUKI ENTERPRISE: RC and steel shield segments, civil/architectural moulds, steel fiber (KOSTEEL BUNDREX®), and PP fiber."
  lang={lang}
>
  <section class="py-20 max-w-6xl mx-auto px-4">
    <h1 class="text-2xl md:text-3xl font-bold border-l-4 border-accent-400 pl-3 mb-2 text-brand-900">
      Products
    </h1>
    <p class="text-sm text-slate-500 mb-10 ml-1">Civil Engineering &amp; Construction Materials</p>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {products.map((product) => (
        <a href={p(product.href)} class="group bg-white border border-slate-200 rounded overflow-hidden shadow-sm hover:shadow-md hover:border-accent-400 transition-all">
          <div class="aspect-video overflow-hidden bg-slate-100">
            <img src={product.img} alt={product.title} width="800" height="450" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="p-5">
            <h3 class="font-bold mb-2 text-brand-900 group-hover:text-brand-600 transition-colors">{product.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{product.desc}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
