---
import Layout from '../../layouts/Layout.astro';
import { getLocalizedPath } from '../../i18n/ui';
const lang = 'en' as const;
const p = (path: string) => getLocalizedPath(path, lang);

const products = [
  { title: 'RC Segment', desc: 'Reinforced-concrete shield-tunnel lining segments, manufactured at overseas partner plants under Japanese-grade quality control.', href: '/products/shield-segment/rc/', img: '/images/products/rc-segment.webp' },
  { title: 'Steel Segment', desc: 'Steel lining segments for gas, subway, and road tunnels — produced to ±1 mm dimensional tolerance.', href: '/products/shield-segment/steel/', img: '/images/products/shield-tunnel.webp' },
  { title: 'Moulds (Formwork)', desc: 'High-precision formwork including RC-segment moulds (±0.5 mm), and PC slab moulds for highway repair.', href: '/products/mold/', img: '/images/products/mould.webp' },
  { title: 'Steel Fiber (BUNDREX®)', desc: 'Structural reinforcement fiber for RC. Sole Japanese distributor of KOSTEEL BUNDREX® (Korea).', href: '/products/concrete-reinforcement/bundrex/', img: '/images/products/steel-fiber.webp' },
  { title: 'Polypropylene Fiber', desc: 'Non-structural PP fiber preventing cracking and spalling. Supplied to leading Japanese general contractors.', href: '/products/concrete-reinforcement/pp-fiber/', img: '/images/products/pp-fiber.webp' },
];
---

<Layout title="SUZUKI ENTERPRISE CO., LTD." lang={lang}>
  <section class="relative bg-brand-900 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-30">
      <div class="w-full h-full bg-gradient-to-br from-slate-700 via-brand-900 to-black"></div>
    </div>
    <div class="absolute inset-0 bg-gradient-to-r from-brand-900/90 to-brand-900/40"></div>
    <div class="relative max-w-6xl mx-auto px-4 py-24 md:py-36">
      <p class="text-xs uppercase tracking-widest text-accent-300 mb-4">Civil Engineering &amp; Construction Materials</p>
      <h1 class="text-3xl md:text-5xl font-bold leading-tight">
        Safety and cost efficiency<br />
        for Asia's infrastructure.
      </h1>
      <p class="mt-6 max-w-2xl text-slate-100 leading-relaxed">
        For over half a century, we have supplied RC and steel segments for shield tunneling, concrete reinforcement fibers, and civil/architectural moulds through our trusted East-Asian sourcing network.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={p('/products/')} class="bg-accent-400 text-brand-900 font-semibold px-5 py-3 rounded hover:bg-accent-300 transition-colors">View Products</a>
        <a href={p('/contact/')} class="border border-white/40 px-5 py-3 rounded hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

  <section class="py-20 bg-slate-50">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-bold border-l-4 border-accent-400 pl-3 mb-8 text-brand-900">
        Civil Engineering &amp; Construction Materials
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {products.map((product) => (
          <a href={p(product.href)} class="group bg-white border border-slate-200 rounded overflow-hidden shadow-sm hover:shadow-md hover:border-accent-400 transition-all">
            <div class="aspect-video overflow-hidden bg-slate-100">
              <img src={product.img} alt={product.title} width="800" height="450" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="p-5">
              <h3 class="font-bold mb-2 text-brand-900 group-hover:text-brand-600 transition-colors">{product.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed">{product.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
