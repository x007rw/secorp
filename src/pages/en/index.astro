---
import Layout from '../../layouts/Layout.astro';
import { getLocalizedPath } from '../../i18n/ui';
import { getProducts, getNews } from '../../lib/microcms';
import { localized } from '../../types/microcms';

const lang = 'en' as const;
const p = (path: string) => getLocalizedPath(path, lang);

const products = await getProducts();
const latestNews = await getNews(3);
---

<Layout title="SUZUKI ENTERPRISE CO., LTD." lang={lang}>
  <section class="relative bg-brand-900 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-40">
      <img
        src="/images/hero-tunnel.webp"
        alt=""
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
        width="1920"
        height="1081"
      />
    </div>
    <div class="absolute inset-0 bg-gradient-to-r from-brand-900/85 to-brand-900/30"></div>
    <div class="relative max-w-6xl mx-auto px-4 py-24 md:py-36">
      <p class="text-xs uppercase tracking-widest text-accent-300 mb-4">Civil Engineering &amp; Construction Materials</p>
      <h1 class="text-3xl md:text-5xl font-bold leading-tight">
        Safety and cost efficiency<br />
        for Asia's infrastructure.
      </h1>
      <p class="mt-6 max-w-2xl text-slate-100 leading-relaxed">
        For over half a century, we have supplied RC and steel segments for shield tunneling, concrete reinforcement fibers, and civil/architectural moulds through our trusted East-Asian sourcing network.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={p('/products/')} class="bg-accent-400 text-brand-900 font-semibold px-5 py-3 rounded hover:bg-accent-300 transition-colors">View Products</a>
        <a href={p('/contact/')} class="border border-white/40 px-5 py-3 rounded hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

  {latestNews.length > 0 && (
    <section class="py-16 bg-slate-50">
      <div class="max-w-6xl mx-auto px-4">
        <div class="flex items-end justify-between mb-8">
          <h2 class="text-2xl md:text-3xl font-bold border-l-4 border-accent-400 pl-3 text-brand-900">
            News
          </h2>
          <a href={p('/news/')} class="text-sm text-brand-600 hover:text-accent-600 font-semibold">
            View all →
          </a>
        </div>
        <ul class="divide-y divide-slate-200 bg-white border border-slate-200 rounded">
          {latestNews.map((n) => (
            <li>
              <a href={p(`/news/${n.slug}/`)} class="flex flex-col md:flex-row md:items-center gap-2 md:gap-6 p-5 hover:bg-slate-50 transition-colors">
                <time class="text-xs text-slate-500 font-mono shrink-0 w-28">
                  {new Date(n.published_at).toLocaleDateString('en-US')}
                </time>
                <span class="text-sm text-slate-800 font-medium">
                  {localized(n, 'title', lang)}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <section class="py-20 bg-slate-50">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-bold border-l-4 border-accent-400 pl-3 mb-8 text-brand-900">
        Civil Engineering &amp; Construction Materials
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {products.map((product) => (
          <a href={p(`/products/${product.slug}/`)} class="group bg-white border border-slate-200 rounded overflow-hidden shadow-sm hover:shadow-md hover:border-accent-400 transition-all">
            <div class="aspect-video overflow-hidden bg-slate-100">
              <img src={product.image.url} alt={localized(product, 'title', lang)} width="800" height="450" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="p-5">
              <h3 class="font-bold mb-2 text-brand-900 group-hover:text-brand-600 transition-colors">{localized(product, 'title', lang)}</h3>
              <p class="text-sm text-slate-600 leading-relaxed">{localized(product, 'excerpt', lang)}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
