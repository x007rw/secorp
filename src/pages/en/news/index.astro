---
import Layout from '../../../layouts/Layout.astro';
import { getLocalizedPath } from '../../../i18n/ui';
import { getNews } from '../../../lib/microcms';
import { localized } from '../../../types/microcms';

const lang = 'en' as const;
const p = (path: string) => getLocalizedPath(path, lang);

const newsList = await getNews(50);

// microCMS の選択肢は日本語に変更済み。英語版では日本語キー→英訳マッピング
const categoryLabel: Record<string, string> = {
  'お知らせ': 'Announcement',
  'メディア掲載': 'Media',
  'イベント': 'Event',
  // 旧英語キー（残存データ用フォールバック）
  announcement: 'Announcement',
  media: 'Media',
  event: 'Event',
};
---

<Layout title="News" description="News, media appearances, and events from SUZUKI ENTERPRISE CO., LTD." lang={lang}>
  <section class="py-20 max-w-4xl mx-auto px-4">
    <h1 class="text-2xl md:text-3xl font-bold border-l-4 border-accent-400 pl-3 mb-10 text-brand-900">
      News &amp; Topics
    </h1>

    {newsList.length === 0 ? (
      <p class="text-slate-600">No news yet.</p>
    ) : (
      <ul class="divide-y divide-slate-200 bg-white border border-slate-200 rounded">
        {newsList.map((n) => (
          <li>
            <a href={p(`/news/${n.slug}/`)} class="flex flex-col md:flex-row md:items-center gap-2 md:gap-6 p-5 hover:bg-slate-50 transition-colors">
              <time class="text-xs text-slate-500 font-mono shrink-0 w-28">
                {new Date(n.published_at).toLocaleDateString('en-US')}
              </time>
              {n.category && n.category[0] && (
                <span class="inline-block text-xs bg-brand-50 text-brand-700 px-2 py-1 rounded shrink-0">
                  {categoryLabel[n.category[0]] ?? n.category[0]}
                </span>
              )}
              <span class="text-sm text-slate-800 font-medium">
                {localized(n, 'title', lang)}
              </span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</Layout>
