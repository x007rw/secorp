---
import Layout from '../../../layouts/Layout.astro';
import { getLocalizedPath } from '../../../i18n/ui';
const lang = 'ja' as const;
const p = (path: string) => getLocalizedPath(path, lang);
---

<Layout
  title="POWER MESH"
  description="高引張強度のメッシュ材 POWER MESH。エンボス加工による高い付着性能。コンクリート表面補強・補修に最適。"
  lang={lang}
>
  <div class="bg-gradient-to-br from-brand to-brand-light text-white py-16">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="text-sm text-gray-300 mb-4">
        <a href={p('/products/')} class="hover:text-white">製品一覧</a> /
        <a href={p('/products/concrete-reinforcement/')} class="hover:text-white">コンクリート補強材</a> /
        <span>POWER MESH</span>
      </nav>
      <p class="text-accent text-sm font-semibold tracking-wider mb-2">POWER MESH</p>
      <h1 class="text-3xl md:text-5xl font-bold">POWER MESH</h1>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 py-16">
    <div class="prose-jp">
      <h2>製品概要</h2>
      <p>
        POWER MESH は、高い引張強度とエンボス加工による優れた付着性能を備えたメッシュ補強材です。コンクリート表面補強・補修分野で広く使用されています。
      </p>

      <h2>仕様</h2>
      <table>
        <tbody>
          <tr><th>引張強度</th><td>171〜261.9 MPa / 362.3 MPa / 524.2 MPa / 530.7 MPa（グレード別）</td></tr>
          <tr><th>梱包</th><td>0.6kg / 0.9kg / 3kg / 4.55kg / 5.46kg / 9.10kg/袋（仕様により異なる）</td></tr>
          <tr><th>色・形状</th><td>灰色凹凸（エンボス加工）</td></tr>
        </tbody>
      </table>

      <h2>特長</h2>
      <ul>
        <li>高引張強度（最大530MPa超）</li>
        <li>エンボス加工による優れたコンクリート付着性</li>
        <li>多様なグレードを取り揃え、用途に応じた選択が可能</li>
      </ul>

      <h2>資料ダウンロード</h2>
      <p>
        <a href="/downloads/power-mesh-spec.pdf" class="inline-block bg-brand text-white px-6 py-2 rounded-md no-underline hover:bg-accent">
          → POWER MESH 仕様書（PDF）
        </a>
      </p>
    </div>
  </div>
</Layout>
