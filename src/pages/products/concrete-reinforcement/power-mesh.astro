---
import Layout from '../../../layouts/Layout.astro';
import { getLocalizedPath } from '../../../i18n/ui';
const lang = 'ja' as const;
const p = (path: string) => getLocalizedPath(path, lang);
---

<Layout
  title="POWER MESH - メッシュ補強材"
  description="高引張強度のメッシュ材 POWER MESH。エンボス加工による高い付着性能。最大530MPa超の引張強度でコンクリート表面補強・補修に最適。"
  lang={lang}
>
  <section class="py-20 max-w-4xl mx-auto px-4">
    <nav class="text-sm text-slate-500 mb-4">
      <a href={p('/products/')} class="hover:text-brand-600">土木・建設資材</a>
      <span class="mx-2">/</span>
      <span>POWER MESH</span>
    </nav>

    <h1 class="text-2xl md:text-3xl font-bold border-l-4 border-accent-400 pl-3 mb-2 text-brand-900">
      POWER MESH
    </h1>
    <p class="text-sm text-slate-500 mb-10 ml-1">High-tensile Mesh Reinforcement</p>

    <div class="prose-jp">
      <h2>製品概要</h2>
      <p>
        POWER MESH は、高い引張強度とエンボス加工による優れた付着性能を備えたメッシュ補強材です。コンクリート表面補強・補修分野で広く使用されています。
      </p>

      <h2>仕様</h2>
      <table>
        <tbody>
          <tr><th>引張強度</th><td>171〜261.9 MPa / 362.3 MPa / 524.2 MPa / 530.7 MPa（グレード別）</td></tr>
          <tr><th>梱包</th><td>0.6kg / 0.9kg / 3kg / 4.55kg / 5.46kg / 9.10kg/袋（仕様により異なる）</td></tr>
          <tr><th>色・形状</th><td>灰色凹凸（エンボス加工）</td></tr>
        </tbody>
      </table>

      <h2>特長</h2>
      <ul>
        <li>高引張強度（最大530MPa超）</li>
        <li>エンボス加工による優れたコンクリート付着性</li>
        <li>多様なグレードを取り揃え、用途に応じた選択が可能</li>
      </ul>
    </div>

    <div class="mt-10">
      <a
        href={p('/contact/')}
        class="bg-brand-900 text-white font-semibold px-5 py-3 rounded hover:bg-brand-700 transition-colors inline-block"
      >
        お問い合わせ →
      </a>
    </div>
  </section>
</Layout>
