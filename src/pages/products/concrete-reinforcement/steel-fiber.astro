---
import Layout from '../../../layouts/Layout.astro';
import { getLocalizedPath } from '../../../i18n/ui';
const lang = 'ja' as const;
const p = (path: string) => getLocalizedPath(path, lang);
---

<Layout
  title="スチール・ファイバー"
  description="RCにおける構造的補強材として使用されるスチールファイバー（鋼繊維）。鉄筋と同等の補強効果を発揮します。"
  lang={lang}
>
  <div class="bg-gradient-to-br from-brand to-brand-light text-white py-16">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="text-sm text-gray-300 mb-4">
        <a href={p('/products/')} class="hover:text-white">製品一覧</a> /
        <a href={p('/products/concrete-reinforcement/')} class="hover:text-white">コンクリート補強材</a> /
        <span>スチール・ファイバー</span>
      </nav>
      <p class="text-accent text-sm font-semibold tracking-wider mb-2">STEEL FIBER</p>
      <h1 class="text-3xl md:text-5xl font-bold">スチール・ファイバー</h1>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 py-16">
    <div class="prose-jp">
      <h2>スチール・ファイバーとは</h2>
      <p>
        スチール・ファイバー（鋼繊維）とはRC（鉄筋コンクリート）において、鉄筋と同じ「構造的補強（Structured Reinforcement）」として使用される補強材です。
      </p>
      <p>
        コンクリートに混合することで、引張強度・靱性・耐衝撃性を大幅に向上させます。シールドトンネルライニング、舗装、耐震補強など幅広い分野で採用されています。
      </p>

      <h2>主要製品</h2>
      <p>
        当社では、ブランド製品「バンドレックス®」をはじめ、多様な仕様のスチールファイバーを取り扱っております。
      </p>

      <p>
        <a href={p('/products/concrete-reinforcement/bundrex/')} class="text-accent font-semibold">
          → バンドレックス® の詳細はこちら
        </a>
      </p>
    </div>
  </div>
</Layout>
