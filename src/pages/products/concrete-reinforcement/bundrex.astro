---
import Layout from '../../../layouts/Layout.astro';
import { getLocalizedPath } from '../../../i18n/ui';
const lang = 'ja' as const;
const p = (path: string) => getLocalizedPath(path, lang);
---

<Layout
  title="バンドレックス® (BUNDREX) - スチール・ファイバー"
  description="鉄筋と同じ「構造的補強」として用いる鋼繊維。韓国KOSTEEL社製 BUNDREX® の日本国内総代理店。JIS適合、ダブルエンドフック型、建設物価登録品。"
  lang={lang}
>
  <section class="py-20 max-w-4xl mx-auto px-4">
    <nav class="text-sm text-slate-500 mb-4">
      <a href={p('/products/')} class="hover:text-brand-600">土木・建設資材</a>
      <span class="mx-2">/</span>
      <span>スチール・ファイバー（バンドレックス®）</span>
    </nav>

    <h1 class="text-2xl md:text-3xl font-bold border-l-4 border-accent-400 pl-3 mb-2 text-brand-900">
      スチール・ファイバー（バンドレックス® / BUNDREX®）
    </h1>
    <p class="text-sm text-slate-500 mb-10 ml-1">Steel Fiber - KOSTEEL BUNDREX®</p>

    <div class="prose-jp">
      <p class="bg-accent-300/20 border-l-4 border-accent-400 p-4 not-prose text-sm">
        当社は韓国 <strong>KOSTEEL CO., LTD.</strong> 社製スチール・ファイバー
        「<strong>BUNDREX®</strong>」の<strong>日本国内総代理店</strong>です。
      </p>

      <h2>製品概要</h2>
      <p>
        スチール・ファイバー（鋼繊維）は、RC（鉄筋コンクリート）において鉄筋と同じ「構造的補強（Structured Reinforcement）」として使用される補強材です。コンクリートに混合することで、引張強度・靱性・耐衝撃性を大幅に向上させます。
      </p>
      <p>
        BUNDREX® はダブルエンドフック型の高品質スチールファイバーで、建設物価に共通資材として登録されており、信頼性の高い補強材として広く採用されています。
      </p>

      <h2>仕様</h2>
      <table>
        <tbody>
          <tr><th>製造メーカー</th><td>韓国 KOSTEEL CO., LTD.</td></tr>
          <tr><th>日本総代理店</th><td>株式会社鈴木エンタープライズ</td></tr>
          <tr><th>材質</th><td>KOSTEEL社製 軟鋼線材</td></tr>
          <tr><th>規格適合</th><td>JIS G3532 適合 / KS D3554（JIS G3505と等価）/ SWRM6</td></tr>
          <tr><th>形状</th><td>ダブルエンドフック型／束（のり接着）</td></tr>
          <tr><th>建設物価登録</th><td>共通資材として登録</td></tr>
          <tr><th>年間供給能力</th><td>SFRCセグメント向け 約2,000MT</td></tr>
        </tbody>
      </table>

      <h2>主な用途</h2>
      <ul>
        <li>シールドトンネルライニングコンクリート（SFRCセグメント）</li>
        <li>床版・舗装の構造補強</li>
        <li>耐震補強</li>
        <li>プレキャスト製品の補強</li>
      </ul>

      <h2>特長</h2>
      <ul>
        <li>ダブルエンドフック構造による高いコンクリート付着力</li>
        <li>JIS適合品質による信頼性</li>
        <li>建設物価登録による調達のしやすさ</li>
        <li>KOSTEEL社の安定した大量供給体制</li>
      </ul>
    </div>

    <div class="mt-10 flex flex-wrap gap-3">
      <a
        href={p('/contact/')}
        class="bg-brand-900 text-white font-semibold px-5 py-3 rounded hover:bg-brand-700 transition-colors"
      >
        お問い合わせ →
      </a>
    </div>
  </section>
</Layout>
