---
import Layout from '../../../layouts/Layout.astro';
import { getLocalizedPath } from '../../../i18n/ui';
const lang = 'ja' as const;
const p = (path: string) => getLocalizedPath(path, lang);
---

<Layout
  title="ポリプロピレン・ファイバー"
  description="コンクリートのひび割れ防止・剥離防止に効果的なポリプロピレン・ファイバー（PP Fiber）。日本の大手ゼネコンに納入実績多数。"
  lang={lang}
>
  <section class="py-20 max-w-4xl mx-auto px-4">
    <nav class="text-sm text-slate-500 mb-4">
      <a href={p('/products/')} class="hover:text-brand-600">土木・建設資材</a>
      <span class="mx-2">/</span>
      <span>ポリプロピレン・ファイバー</span>
    </nav>

    <h1 class="text-2xl md:text-3xl font-bold border-l-4 border-accent-400 pl-3 mb-2 text-brand-900">
      ポリプロピレン・ファイバー
    </h1>
    <p class="text-sm text-slate-500 mb-10 ml-1">Polypropylene Fiber</p>

    <div class="prose-jp">
      <h2>ポリプロピレン・ファイバーとは</h2>
      <p>
        ポリプロピレン・ファイバー（PP Fiber）とは、コンクリートに混ぜて使用する「非構造的補強（Non-Structured Reinforcement）」用の繊維補強材です。主に<strong>ひび割れ防止・剥離防止</strong>を目的として使用されます。
      </p>
      <p>
        当社が供給する高強度PP繊維は、日本の大手ゼネコンに納入実績があります。
      </p>

      <h2>主な効果</h2>
      <ul>
        <li>コンクリート初期硬化時のひび割れ防止</li>
        <li>表面剥離（爆裂）防止</li>
        <li>耐衝撃性の向上</li>
        <li>耐火性能の改善（爆裂対策）</li>
      </ul>

      <h2>主な用途</h2>
      <ul>
        <li>トンネルライニングコンクリート</li>
        <li>床版・舗装</li>
        <li>プレキャスト製品</li>
        <li>耐火構造物</li>
      </ul>
    </div>

    <div class="mt-10">
      <a
        href={p('/contact/')}
        class="bg-brand-900 text-white font-semibold px-5 py-3 rounded hover:bg-brand-700 transition-colors inline-block"
      >
        お問い合わせ →
      </a>
    </div>
  </section>
</Layout>
