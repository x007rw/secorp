---
import Layout from '../../layouts/Layout.astro';
import { getLocalizedPath } from '../../i18n/ui';
const lang = 'ja' as const;
const p = (path: string) => getLocalizedPath(path, lang);

const products = [
  {
    title: 'RCセグメント',
    en: 'RC Segment',
    desc: 'シールド工法で構築されるトンネルの鉄筋コンクリート製内壁パーツ。日本基準のセグメントを海外提携工場で監理生産します。',
    href: '/products/shield-segment/rc/',
  },
  {
    title: '鋼製セグメント',
    en: 'Steel Segment',
    desc: 'ガス導管・地下鉄・道路トンネル等に用いる鋼製の内壁セグメント。寸法精度 ±1mm 以内で量産対応。',
    href: '/products/shield-segment/steel/',
  },
  {
    title: '土木・建築用型枠',
    en: 'Moulds (Formwork)',
    desc: 'RCセグメント用型枠など、±0.5mm 以内の寸法精度を要求される高精度型枠。PC床板用型枠の海外製作にも対応。',
    href: '/products/mold/',
  },
  {
    title: 'スチール・ファイバー',
    en: 'Steel Fiber',
    desc: '鉄筋と同じ「構造的補強」として用いる鋼繊維。韓国KOSTEEL社製 BUNDREX® の日本国内総代理店です。',
    href: '/products/concrete-reinforcement/bundrex/',
  },
  {
    title: 'ポリプロピレン・ファイバー',
    en: 'Polypropylene Fiber',
    desc: 'コンクリートの非構造的補強(ひび割れ・剥離防止)に用いる高強度PP繊維。日本の大手ゼネコンに納入実績。',
    href: '/products/concrete-reinforcement/pp-fiber/',
  },
  {
    title: 'POWER MESH',
    en: 'Power Mesh',
    desc: '高引張強度（最大530MPa超）のメッシュ補強材。エンボス加工による優れたコンクリート付着性能。',
    href: '/products/concrete-reinforcement/power-mesh/',
  },
];
---

<Layout
  title="土木・建設資材"
  description="鈴木エンタープライズの取扱製品一覧：RC/鋼製セグメント、土木建築用型枠、スチール・ファイバー（KOSTEEL BUNDREX®）、ポリプロピレン・ファイバー、POWER MESH。"
  lang={lang}
>
  <section class="py-20 max-w-6xl mx-auto px-4">
    <h1 class="text-2xl md:text-3xl font-bold border-l-4 border-accent-400 pl-3 mb-2 text-brand-900">
      土木・建設資材
    </h1>
    <p class="text-sm text-slate-500 mb-10 ml-1">Civil Engineering &amp; Construction Materials</p>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {products.map((product) => (
        <a
          href={p(product.href)}
          class="group bg-white border border-slate-200 rounded overflow-hidden shadow-sm hover:shadow-md hover:border-accent-400 transition-all"
        >
          <div class="aspect-video bg-gradient-to-br from-slate-200 to-slate-300 flex items-center justify-center">
            <span class="text-slate-500 text-xs uppercase tracking-wider">{product.en}</span>
          </div>
          <div class="p-5">
            <h3 class="font-bold mb-2 text-brand-900 group-hover:text-brand-600 transition-colors">
              {product.title}
            </h3>
            <p class="text-sm text-slate-600 leading-relaxed">{product.desc}</p>
            <span class="inline-block mt-3 text-xs font-semibold text-accent-600">詳しく見る →</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
