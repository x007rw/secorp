---
import Layout from '../../../layouts/Layout.astro';
import { getLocalizedPath } from '../../../i18n/ui';
const lang = 'ja' as const;
const p = (path: string) => getLocalizedPath(path, lang);
---

<Layout
  title="RCセグメント"
  description="シールド工法用のRC（鉄筋コンクリート）セグメント。日本基準のセグメントを海外提携工場で監理生産。横浜市営地下鉄・シンガポールMRTほか納入実績多数。"
  lang={lang}
>
  <section class="py-20 max-w-4xl mx-auto px-4">
    <nav class="text-sm text-slate-500 mb-4">
      <a href={p('/products/')} class="hover:text-brand-600">土木・建設資材</a>
      <span class="mx-2">/</span>
      <span>RCセグメント</span>
    </nav>

    <h1 class="text-2xl md:text-3xl font-bold border-l-4 border-accent-400 pl-3 mb-2 text-brand-900">
      RCセグメント
    </h1>
    <p class="text-sm text-slate-500 mb-10 ml-1">RC Segment</p>

    <div class="prose-jp">
      <h2>製品概要</h2>
      <p>
        RCセグメント（Reinforced Concrete Segment）は、シールド工法によって構築されるトンネルの鉄筋コンクリート製内壁パーツです。耐圧縮性・耐久性に優れ、長期使用のインフラトンネルに広く採用されています。
      </p>
      <p>
        当社では、日本基準に準拠したセグメントを<strong>海外提携工場で監理生産</strong>し、国内ゼネコン・公共事業者にお届けしています。日本の品質基準を維持しながら、グローバルな調達によるコスト競争力を実現しています。
      </p>

      <h2>主な用途</h2>
      <ul>
        <li>地下鉄・鉄道トンネル</li>
        <li>大規模上下水道トンネル</li>
        <li>大深度地下トンネル</li>
        <li>共同溝・電力・通信用トンネル</li>
      </ul>

      <h2>特長</h2>
      <ul>
        <li>高い耐圧縮性能と長期耐久性</li>
        <li>日本基準（JIS規格）への適合</li>
        <li>海外調達によるコスト効率</li>
        <li>大型・特殊形状にも対応</li>
      </ul>

      <h2>主要納入実績</h2>
      <ul>
        <li>横浜市営地下鉄 4号線 白楽工区</li>
        <li>シンガポール地下鉄 C-823 工区</li>
        <li>国土交通省関連 シールド事業</li>
        <li>各地下鉄・電気・ガス・水道シールド事業</li>
      </ul>
    </div>

    <div class="mt-10 flex flex-wrap gap-3">
      <a
        href={p('/contact/')}
        class="bg-brand-900 text-white font-semibold px-5 py-3 rounded hover:bg-brand-700 transition-colors"
      >
        お問い合わせ →
      </a>
    </div>
  </section>
</Layout>
