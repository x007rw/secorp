---
import Layout from '../../../layouts/Layout.astro';
import { getLocalizedPath } from '../../../i18n/ui';
const lang = 'ja' as const;
const p = (path: string) => getLocalizedPath(path, lang);
---

<Layout
  title="シールドセグメント"
  description="シールド工法用セグメント（鋼製・RC）の専門商社。日本基準のセグメントを海外提携工場で監理生産。寸法精度±1mmの鋼製セグメントから大型RCセグメントまで対応。"
  lang={lang}
>
  <section class="py-20 max-w-4xl mx-auto px-4">
    <nav class="text-sm text-slate-500 mb-4">
      <a href={p('/products/')} class="hover:text-brand-600">土木・建設資材</a>
      <span class="mx-2">/</span>
      <span>シールドセグメント</span>
    </nav>

    <h1 class="text-2xl md:text-3xl font-bold border-l-4 border-accent-400 pl-3 mb-2 text-brand-900">
      シールドセグメント
    </h1>
    <p class="text-sm text-slate-500 mb-10 ml-1">Shield Segment</p>

    <div class="prose-jp">
      <p>
        セグメントとは、シールド工法によって構築されるトンネルの内壁を構成するパーツです。地下鉄・上下水道・電力・通信用トンネル、道路トンネル、ガス導管トンネルなど、都市インフラの建設に不可欠な部材です。
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-4 mt-8">
      <a
        href={p('/products/shield-segment/rc/')}
        class="group bg-white border border-slate-200 rounded p-6 hover:shadow-md hover:border-accent-400 transition-all"
      >
        <p class="text-xs text-slate-500 uppercase tracking-wider mb-1">RC Segment</p>
        <h2 class="text-lg font-bold text-brand-900 mb-2 group-hover:text-brand-600">RCセグメント</h2>
        <p class="text-sm text-slate-600 leading-relaxed">
          鉄筋コンクリート構造で耐圧縮性・耐久性に優れる。長期使用インフラに最適。日本基準を海外提携工場で監理生産。
        </p>
      </a>

      <a
        href={p('/products/shield-segment/steel/')}
        class="group bg-white border border-slate-200 rounded p-6 hover:shadow-md hover:border-accent-400 transition-all"
      >
        <p class="text-xs text-slate-500 uppercase tracking-wider mb-1">Steel Segment</p>
        <h2 class="text-lg font-bold text-brand-900 mb-2 group-hover:text-brand-600">鋼製セグメント</h2>
        <p class="text-sm text-slate-600 leading-relaxed">
          ガス導管・地下鉄・道路トンネル等に用いる鋼製の内壁セグメント。寸法精度 ±1mm 以内で量産対応。
        </p>
      </a>
    </div>
  </section>
</Layout>
