---
import { useTranslations, getLocalizedPath, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = useTranslations(lang);
const p = (path: string) => getLocalizedPath(path, lang);

const navItems = [
  { label: t('nav.about'), href: p('/company/about/') },
  { label: t('nav.philosophy'), href: p('/company/philosophy/') },
  { label: t('nav.products'), href: p('/products/') },
  { label: t('nav.history'), href: p('/company/history/') },
  { label: t('nav.contact'), href: p('/contact/') },
];

const jaPath = currentPath.replace(/^\/en/, '') || '/';
const enPath = lang === 'en' ? currentPath : `/en${currentPath}`.replace(/\/+$/, '/');
---

<header class="fixed top-0 inset-x-0 z-40 bg-white/90 backdrop-blur border-b border-slate-200">
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between gap-3">
    <a href={p('/')} class="flex items-center gap-2.5 group min-w-0">
      <img
        src="/images/logo.svg"
        alt={t('site.name')}
        width="56"
        height="56"
        class="h-12 w-auto shrink-0"
      />
      <span class="font-bold text-sm sm:text-base text-brand-900 truncate">
        {t('site.name')}
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-6 text-sm">
      {navItems.map((item) => (
        <a href={item.href} class="text-slate-700 hover:text-brand-600 transition-colors">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <!-- Desktop: language pills -->
      <div class="hidden md:flex items-center gap-2 text-xs">
        <a
          href={jaPath}
          class={`px-2 py-1 rounded border ${lang === 'ja' ? 'bg-brand-900 text-white border-brand-900' : 'border-slate-300 hover:bg-slate-100'}`}
          hreflang="ja"
        >日本語</a>
        <a
          href={enPath}
          class={`px-2 py-1 rounded border ${lang === 'en' ? 'bg-brand-900 text-white border-brand-900' : 'border-slate-300 hover:bg-slate-100'}`}
          hreflang="en"
        >English</a>
      </div>

      <!-- Mobile: hamburger only -->
      <button
        id="menu-toggle"
        type="button"
        class="md:hidden p-2 -mr-2 text-slate-700"
        aria-label="menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="menu-icon-open" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-icon-close" class="hidden" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu drawer -->
  <nav id="mobile-menu" class="hidden md:hidden border-t border-slate-200 bg-white">
    <ul class="px-4 py-1">
      {navItems.map((item) => (
        <li>
          <a href={item.href} class="block py-3 text-base text-slate-700 border-b border-slate-100">
            {item.label}
          </a>
        </li>
      ))}
    </ul>
    <div class="px-4 py-4 bg-slate-50 border-t border-slate-200">
      <p class="text-xs text-slate-500 uppercase tracking-wider mb-2">Language</p>
      <div class="grid grid-cols-2 gap-2">
        <a
          href={jaPath}
          class={`text-center py-2.5 rounded text-sm font-medium border transition-colors ${lang === 'ja' ? 'bg-brand-900 text-white border-brand-900' : 'bg-white border-slate-300 text-slate-700 hover:bg-slate-100'}`}
          hreflang="ja"
        >日本語</a>
        <a
          href={enPath}
          class={`text-center py-2.5 rounded text-sm font-medium border transition-colors ${lang === 'en' ? 'bg-brand-900 text-white border-brand-900' : 'bg-white border-slate-300 text-slate-700 hover:bg-slate-100'}`}
          hreflang="en"
        >English</a>
      </div>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle?.setAttribute('aria-expanded', String(isOpen));
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });

  // Close menu when a nav link is clicked
  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      menu?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    })
  );
</script>
