---
import { useTranslations, getLocalizedPath, type Lang, languages } from '../i18n/ui';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = useTranslations(lang);
const p = (path: string) => getLocalizedPath(path, lang);

const navItems = [
  { label: t('nav.about'), href: p('/company/about/') },
  { label: t('nav.philosophy'), href: p('/company/philosophy/') },
  { label: t('nav.products'), href: p('/products/') },
  { label: t('nav.history'), href: p('/company/history/') },
  { label: t('nav.contact'), href: p('/contact/') },
];

const altLang: Lang = lang === 'ja' ? 'en' : 'ja';
const stripped = currentPath.replace(/^\/en/, '') || '/';
const altPath = altLang === 'ja' ? stripped : `/en${stripped}`.replace(/\/+$/, '/');
---

<header class="fixed top-0 inset-x-0 z-40 bg-white/90 backdrop-blur border-b border-slate-200">
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between gap-4">
    <a href={p('/')} class="flex items-center gap-2.5 group">
      <div class="w-8 h-8 bg-brand-900 text-white rounded flex items-center justify-center font-bold text-sm">SE</div>
      <span class="font-bold text-sm sm:text-base text-brand-900">
        {t('site.name')}
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-6 text-sm">
      {navItems.map((item) => (
        <a href={item.href} class="text-slate-700 hover:text-brand-600 transition-colors">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2 text-xs">
      <a
        href={lang === 'ja' ? currentPath : (currentPath.replace(/^\/en/, '') || '/')}
        class={`px-2 py-1 rounded border ${lang === 'ja' ? 'bg-brand-900 text-white border-brand-900' : 'border-slate-300 hover:bg-slate-100'}`}
        hreflang="ja"
      >日本語</a>
      <a
        href={lang === 'en' ? currentPath : `/en${currentPath}`.replace(/\/+$/, '/')}
        class={`px-2 py-1 rounded border ${lang === 'en' ? 'bg-brand-900 text-white border-brand-900' : 'border-slate-300 hover:bg-slate-100'}`}
        hreflang="en"
      >English</a>
      <button id="menu-toggle" class="md:hidden ml-1 p-2 -mr-2" aria-label="menu">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-menu" class="hidden md:hidden border-t border-slate-200 bg-white">
    <ul class="px-4 py-2 text-sm divide-y divide-slate-100">
      {navItems.map((item) => (
        <li><a href={item.href} class="block py-3 text-slate-700">{item.label}</a></li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => menu?.classList.add('hidden'))
  );
</script>
