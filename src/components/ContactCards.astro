---
interface Props {
  lang?: 'ja' | 'en';
}

const { lang = 'ja' } = Astro.props;

const labels = {
  ja: {
    tel: '受付：平日 9:00–17:30（土日祝休）',
    copy: 'コピー',
    copied: 'コピーしました',
    openMailer: 'メールアプリで開く',
    openGmail: 'Gmail で開く',
  },
  en: {
    tel: 'Mon–Fri 9:00–17:30 JST',
    copy: 'Copy',
    copied: 'Copied',
    openMailer: 'Open in mail app',
    openGmail: 'Open in Gmail',
  },
}[lang];

const email = 'info@secorp.co.jp';
const gmailUrl = `https://mail.google.com/mail/?view=cm&fs=1&to=${email}`;

const tel = lang === 'ja' ? '044-433-6399' : '+81-44-433-6399';
const fax = lang === 'ja' ? '044-434-8488' : '+81-44-434-8488';

const iconEmail = '<path stroke-linecap="round" stroke-linejoin="round" d="M3 8l9 6 9-6M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />';
const iconTel = '<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11 11 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />';
const iconFax = '<path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />';
---

<div class="bg-white border border-slate-200 rounded shadow-sm overflow-hidden">
  <!-- Email -->
  <div class="flex items-start gap-4 md:gap-5 p-5 md:p-6 border-b border-slate-200">
    <div class="w-12 h-12 rounded-full text-white flex items-center justify-center shrink-0 bg-brand-900">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={iconEmail} />
    </div>
    <div class="flex-1 min-w-0">
      <p class="text-xs text-slate-500 uppercase tracking-wider">Email</p>
      <p class="text-lg md:text-xl font-semibold text-brand-900 break-all">{email}</p>
      <div class="mt-2 flex flex-wrap gap-3 text-xs">
        <a
          href={`mailto:${email}`}
          class="inline-flex items-center gap-1 text-brand-600 hover:text-accent-600 hover:underline"
        >
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" />
          </svg>
          {labels.openMailer}
        </a>
        <a
          href={gmailUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-1 text-brand-600 hover:text-accent-600 hover:underline"
        >
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 3h7v7M10 14L21 3M21 14v6a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h6" />
          </svg>
          {labels.openGmail}
        </a>
      </div>
    </div>
    <button
      type="button"
      class="copy-btn shrink-0 inline-flex items-center gap-1.5 px-3 py-2 text-xs font-semibold text-slate-600 bg-slate-100 hover:bg-slate-200 active:bg-slate-300 rounded transition-colors"
      data-copy={email}
      data-copied-label={labels.copied}
      data-default-label={labels.copy}
      aria-label={`Email ${labels.copy}`}
    >
      <svg class="copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="9" y="9" width="13" height="13" rx="2" />
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
      </svg>
      <svg class="check-icon hidden text-emerald-600" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
      <span class="copy-label">{labels.copy}</span>
    </button>
  </div>

  <!-- TEL -->
  <div class="flex items-center gap-4 md:gap-5 p-5 md:p-6 border-b border-slate-200">
    <div class="w-12 h-12 rounded-full text-white flex items-center justify-center shrink-0 bg-brand-900">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={iconTel} />
    </div>
    <div class="flex-1 min-w-0">
      <p class="text-xs text-slate-500 uppercase tracking-wider">TEL</p>
      <a href="tel:0444336399" class="text-lg md:text-xl font-semibold text-brand-600 hover:text-accent-600 transition-colors">
        {tel}
      </a>
      <p class="text-xs text-slate-500 mt-1">{labels.tel}</p>
    </div>
    <button
      type="button"
      class="copy-btn shrink-0 inline-flex items-center gap-1.5 px-3 py-2 text-xs font-semibold text-slate-600 bg-slate-100 hover:bg-slate-200 active:bg-slate-300 rounded transition-colors"
      data-copy="044-433-6399"
      data-copied-label={labels.copied}
      data-default-label={labels.copy}
      aria-label={`TEL ${labels.copy}`}
    >
      <svg class="copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="9" y="9" width="13" height="13" rx="2" />
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
      </svg>
      <svg class="check-icon hidden text-emerald-600" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
      <span class="copy-label">{labels.copy}</span>
    </button>
  </div>

  <!-- FAX -->
  <div class="flex items-center gap-4 md:gap-5 p-5 md:p-6">
    <div class="w-12 h-12 rounded-full flex items-center justify-center shrink-0 bg-slate-200 text-slate-600">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={iconFax} />
    </div>
    <div class="flex-1 min-w-0">
      <p class="text-xs text-slate-500 uppercase tracking-wider">FAX</p>
      <p class="text-lg md:text-xl font-semibold text-slate-800">{fax}</p>
    </div>
    <button
      type="button"
      class="copy-btn shrink-0 inline-flex items-center gap-1.5 px-3 py-2 text-xs font-semibold text-slate-600 bg-slate-100 hover:bg-slate-200 active:bg-slate-300 rounded transition-colors"
      data-copy="044-434-8488"
      data-copied-label={labels.copied}
      data-default-label={labels.copy}
      aria-label={`FAX ${labels.copy}`}
    >
      <svg class="copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="9" y="9" width="13" height="13" rx="2" />
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
      </svg>
      <svg class="check-icon hidden text-emerald-600" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
      <span class="copy-label">{labels.copy}</span>
    </button>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      e.stopPropagation();

      const text = btn.dataset.copy ?? '';
      const copiedLabel = btn.dataset.copiedLabel ?? 'Copied';
      const defaultLabel = btn.dataset.defaultLabel ?? 'Copy';
      const labelEl = btn.querySelector('.copy-label') as HTMLElement | null;
      const copyIcon = btn.querySelector('.copy-icon') as HTMLElement | null;
      const checkIcon = btn.querySelector('.check-icon') as HTMLElement | null;

      try {
        await navigator.clipboard.writeText(text);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
      }

      if (labelEl) labelEl.textContent = copiedLabel;
      copyIcon?.classList.add('hidden');
      checkIcon?.classList.remove('hidden');
      btn.classList.add('bg-emerald-50', 'text-emerald-700');
      btn.classList.remove('bg-slate-100', 'hover:bg-slate-200', 'text-slate-600');

      setTimeout(() => {
        if (labelEl) labelEl.textContent = defaultLabel;
        copyIcon?.classList.remove('hidden');
        checkIcon?.classList.add('hidden');
        btn.classList.remove('bg-emerald-50', 'text-emerald-700');
        btn.classList.add('bg-slate-100', 'hover:bg-slate-200', 'text-slate-600');
      }, 1800);
    });
  });
</script>
