---
import { useTranslations, getLocalizedPath, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const p = (path: string) => getLocalizedPath(path, lang);
---

<footer class="bg-brand-900 text-slate-300 text-sm mt-20">
  <div class="max-w-6xl mx-auto px-4 py-12 grid md:grid-cols-3 gap-8">
    <div>
      <div class="flex items-center gap-3 mb-4">
        <img
          src="/images/logo.svg"
          alt={t('site.name')}
          width="56"
          height="56"
          class="h-14 w-auto bg-white p-1.5 rounded"
        />
        <p class="font-bold text-white">{t('site.name')}</p>
      </div>
      <p class="text-slate-400 leading-relaxed">
        〒211-0025<br />
        {t('footer.address')}
      </p>
    </div>
    <div>
      <p class="font-bold text-white mb-3">Menu</p>
      <ul class="space-y-1.5">
        <li><a href={p('/company/about/')} class="hover:text-white">{t('nav.about')}</a></li>
        <li><a href={p('/company/philosophy/')} class="hover:text-white">{t('nav.philosophy')}</a></li>
        <li><a href={p('/products/')} class="hover:text-white">{t('nav.products')}</a></li>
        <li><a href={p('/company/history/')} class="hover:text-white">{t('nav.history')}</a></li>
        <li><a href={p('/contact/')} class="hover:text-white">{t('nav.contact')}</a></li>
      </ul>
    </div>
    <div>
      <p class="font-bold text-white mb-3">Contact</p>
      <p>{t('footer.tel')}</p>
      <p>{t('footer.fax')}</p>
      <p class="mt-3">
        <a href={p('/legal/privacy/')} class="text-slate-400 hover:text-white">{t('footer.privacy')}</a>
      </p>
    </div>
  </div>
  <div class="border-t border-white/10">
    <p class="max-w-6xl mx-auto px-4 py-4 text-xs text-slate-400">
      © SUZUKI ENTERPRISE CO., LTD.
    </p>
  </div>
</footer>
