# microCMS（本番ビルド時に取得）
# サービスIDは https://{ここ}.microcms.io の {ここ} 部分
MICROCMS_SERVICE_DOMAIN=secorp

# 公開ビルド用（GET権限のみのキーを推奨）
MICROCMS_API_KEY=

# DeepL自動翻訳スクリプト用（書き込み権限が必要）
# scripts/translate.mjs を実行するときだけ必要
MICROCMS_WRITE_API_KEY=

# DeepL API キー（無料プラン: https://www.deepl.com/pro-api）
# 月50万文字まで無料、クレカ登録のみで課金なし
DEEPL_API_KEY=
