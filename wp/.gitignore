# 環境変数（パスワード等）
.env

# WordPress コア・コンテンツ（コンテナ管理）
wp-content/uploads/*
!wp-content/uploads/.gitkeep
wp-content/upgrade/
wp-content/cache/
wp-content/db.php
wp-content/object-cache.php
wp-content/advanced-cache.php
wp-content/wp-cache-config.php

# プラグインは個別追加判断（基本は除外）
wp-content/plugins/*
!wp-content/plugins/.gitkeep
!wp-content/plugins/secorp-*

# WordPress デフォルトテーマは追跡しない（自作 secorp テーマのみ管理）
wp-content/themes/*
!wp-content/themes/secorp/
!wp-content/themes/.gitkeep

# WordPress コアファイルが volume で混入した場合
wp-content/index.php

# OS・エディタ
.DS_Store
Thumbs.db
*.swp
*.swo
